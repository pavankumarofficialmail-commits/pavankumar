"use client";

// @flow strict
import * as React from "react";
import { FiTag, FiTool, FiUser, FiFileText } from "react-icons/fi";

function ProjectCard({ project }) {
  const description = (project.description || "").trim();

  return (
    <div className="w-full max-w-3xl mx-auto mb-8 md:mb-10 pb-8 md:pb-0">
      <div className="from-[#0d1224] border-[#1b2c68a0] relative rounded-lg border bg-gradient-to-r to-[#0a0d37] overflow-hidden">

        {/* Header */}
        <div className="px-4 lg:px-8 py-3 lg:py-5 border-b border-indigo-900">
          <div className="flex items-center justify-between">
            {/* mac dots */}
            <div className="flex items-center space-x-2">
              <span className="h-3 w-3 rounded-full bg-red-400" />
              <span className="h-3 w-3 rounded-full bg-orange-400" />
              <span className="h-3 w-3 rounded-full bg-green-200" />
            </div>

            {/* Title */}
            <h3 className="text-center w-full text-[#16f2b3] text-lg sm:text-xl lg:text-2xl font-semibold tracking-wide">
              {project.name}
            </h3>

            <div style={{ width: 40 }} />
          </div>
        </div>

        {/* Content */}
        <div className="px-4 lg:px-10 py-6 lg:py-8">

          {/* Name */}
          <div className="flex items-start gap-3 mb-4">
            <div className="text-pink-400 mt-1">
              <FiTag size={18} />
            </div>

            <div>
              <span className="text-gray-200 text-sm mr-2">name:</span>
              <span className="text-amber-300 font-medium">
                {project.name}
              </span>
            </div>
          </div>

          {/* Tools */}
          <div className="flex items-start gap-3 mb-6">
            <div className="text-yellow-400 mt-1">
              <FiTool size={18} />
            </div>

            <div className="w-full">
              <div className="text-gray-200 text-sm mb-3 font-medium">
                tools:
              </div>

              <div className="flex flex-wrap gap-3">
                {project.tools?.map((tool, i) => (
                  <span
                    key={i}
                    className="px-3 py-1 rounded-md border border-yellow-600 text-amber-300 text-[12px] sm:text-sm"
                  >
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          </div>

          {/* Role */}
          <div className="flex items-start gap-3 mb-6">
            <div className="text-green-400 mt-1">
              <FiUser size={18} />
            </div>

            <div>
              <span className="text-gray-200 text-sm mr-2 font-medium">
                myRole:
              </span>

              <span className="text-orange-400 font-medium">
                {project.role}
              </span>
            </div>
          </div>

          {/* Description Title */}
          <div className="flex items-start gap-3 mb-3">
            <div className="text-cyan-400 mt-1">
              <FiFileText size={18} />
            </div>

            <div className="text-gray-200 text-sm font-medium">
              Description:
            </div>
          </div>

          {/* Description */}
          <p
            className="text-cyan-400 leading-7 sm:leading-8 text-[14px] sm:text-[15px] md:text-base transition-all duration-700"
            style={{
              background:
                "linear-gradient(90deg,#22d3ee,#67e8f9,#22d3ee)",
              WebkitBackgroundClip: "text",
              WebkitTextFillColor: "transparent",
              backgroundSize: "200% auto",
              animation: "readingFlow 6s linear infinite"
            }}
          >
            {description}
          </p>

          {/* Small spacer keeps the last description line clear before next sticky card appears */}
          <div className="h-4 md:h-6" />

        </div>
      </div>

      {/* Animation keyframes (client-side) */}
      <style jsx global>{`
        @keyframes readingFlow {
          0% { background-position: 0% center; }
          100% { background-position: 200% center; }
        }

        /* small safeguard: if user prefers reduced motion, stop the animation */
        @media (prefers-reduced-motion: reduce) {
          p[style] {
            animation: none !important;
            -webkit-text-fill-color: #06b6d4 !important;
            background: none !important;
          }
        }
      `}</style>
    </div>
  );
}

export default ProjectCard;
