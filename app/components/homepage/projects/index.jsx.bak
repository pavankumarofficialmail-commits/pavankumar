"use client";

import React, { useEffect, useState } from "react";
import { projectsData } from "@/utils/data/projects-data";
import ProjectCard from "./project-card";

// Tuning constants:
// - MOBILE_BREAKPOINT: switch point for mobile behavior.
// - MOBILE_TOP_OFFSET: sticky top offset on mobile in px.
// - MINHEIGHT_PERCENT: mobile sticky card height percent via --vh fallback.
//   Increase MINHEIGHT_PERCENT (82 -> 85/90) to delay next card takeover on mobile.
const MOBILE_BREAKPOINT = 768;
const MOBILE_TOP_OFFSET = 88;
const MINHEIGHT_PERCENT = 82;

export default function Projects() {
  const [isMobile, setIsMobile] = useState(false);

  // Mobile 100vh fix: track visual viewport height in a CSS variable.
  useEffect(() => {
    const updateVh = () => {
      const vh = (window.visualViewport ? window.visualViewport.height : window.innerHeight) * 0.01;
      document.documentElement.style.setProperty("--vh", `${vh}px`);
    };

    updateVh();

    if (window.visualViewport) {
      window.visualViewport.addEventListener("resize", updateVh);
    }
    window.addEventListener("resize", updateVh);

    return () => {
      if (window.visualViewport) {
        window.visualViewport.removeEventListener("resize", updateVh);
      }
      window.removeEventListener("resize", updateVh);
    };
  }, []);

  useEffect(() => {
    const updateIsMobile = () => {
      setIsMobile(window.innerWidth <= MOBILE_BREAKPOINT);
    };

    updateIsMobile();
    window.addEventListener("resize", updateIsMobile);

    return () => window.removeEventListener("resize", updateIsMobile);
  }, []);

  return (
    <section id="projects" className={`relative z-50 ${isMobile ? "my-8" : "my-12 lg:my-24"}`}>
      <div className={`sticky ${isMobile ? "top-0 bg-transparent z-40" : "top-10"}`}>
        <div className={isMobile ? "pt-6" : ""}>
          <div
            className={`${isMobile ? "w-[60px] h-[60px]" : "w-[80px] h-[80px]"} bg-violet-100 rounded-full absolute -top-3 left-0 translate-x-1/2 filter blur-3xl opacity-30`}
          />
          <div className={`flex items-center justify-start relative ${isMobile ? "px-4" : ""}`}>
            <span
              className={`bg-[#1a1443] absolute left-0 w-fit text-white rounded-md ${isMobile ? "px-4 py-2 text-base" : "px-5 py-3 text-xl"}`}
            >
              PROJECTS
            </span>
            <span className="w-full h-[2px] bg-[#1a1443]" />
          </div>
        </div>
      </div>

      <div className={isMobile ? "pt-20" : "pt-24"}>
        <div className={`flex flex-col ${isMobile ? "gap-8" : "gap-20 md:gap-6"}`}>
          {projectsData.slice(0, 4).map((project, index) => (
            <div key={index} className="w-full mx-auto max-w-2xl flex-none">
              <div
                className="w-full sticky"
                style={{
                  top: isMobile
                    ? `${MOBILE_TOP_OFFSET}px`
                    : `${10 + index * 60}px`,
                  minHeight: isMobile
                    ? `calc(var(--vh, 1vh) * ${MINHEIGHT_PERCENT})`
                    : "85vh",
                }}
              >
                <div
                  className={`box-border flex items-center justify-center rounded transition-all duration-[0.5s] ${isMobile ? "shadow-[0_12px_30px_rgba(0,0,0,0.35)]" : "shadow-[0_0_30px_0_rgba(0,0,0,0.3)]"}`}
                >
                  <ProjectCard project={project} />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}
